# FlashAiNews Configuration Example
# Copy this file to config.toml and update with your settings

[model]
# Model name to use for generating briefs
model = "gpt-4"

# Provider options: "openai", "deepseek", "gemini", "other"
# API keys are read from environment variables:
#   - openai: OPENAI_API_KEY
#   - deepseek: DEEPSEEK_API_KEY  
#   - gemini: GEMINI_API_KEY
#   - other: MODEL_API_KEY
provider = "openai"

# Base URL is automatically determined for built-in providers:
#   - openai: https://api.openai.com/v1
#   - deepseek: https://api.deepseek.com
#   - gemini: (uses Google SDK)
# 
# Only required when provider = "other":
# base_url = "https://your-custom-api.com/v1"


[rate_limit]
# Rate limiting settings (all fields are optional, defaults shown below)

# Maximum requests per minute to the LLM API
requests_per_minute = 60.0

# Maximum burst size for the token bucket rate limiter
burst_size = 10

# Enable/disable rate limiting (default: true)
enable_rate_limit = true

# Retry settings for handling transient API errors

# Maximum number of retry attempts on failure
max_retries = 3

# Base delay in seconds for exponential backoff
base_delay = 1.0

# Maximum delay in seconds between retries
max_delay = 60.0

# Enable/disable automatic retry on errors (default: true)
enable_retry = true

[context]
# Context window settings
max_tokens = 128000               # Maximum token count for the context window
compress_threshold = 0.8          # Threshold (0-1) at which to trigger compression
compress_strategy = "truncate"    # Compression strategy: summary, truncate, priority

# Content optimization settings
article_max_length = 500          # Maximum length for article content (characters)
summary_max_length = 200          # Maximum length for article summaries (characters)
memory_max_length = 300           # Maximum length for history memories (characters)


history_max_messages = 50         # Maximum number of messages to keep
compression_strategy = "sliding_window"  # sliding_window, summary, selective
keep_system = true                # Whether to always keep system messages

# Tool result limits (applies before tool results are appended to messages)
tool_result_max_chars = 5000      # Maximum characters per tool result message
tool_result_max_items = 20        # Maximum items for large list-like tool results (e.g. articles)

[agent_limits]
# Plan & Solve Agent loop limiting configuration
# All fields are optional, defaults shown below

# Research phase limits
max_iterations = 10               # Max research planner iterations (default: 10)
max_tool_calls = 50               # Max total tool calls across all phases (default: 50)
max_curations = 8                 # Max material curation cycles (default: 8)

# Review phase limits
max_plan_reviews = 3              # Max plan review cycles (default: 3)

# Writing phase limits
max_refines = 3                   # Max draft refinement cycles (default: 3)

# Enable/disable Layer 1 (state-level hard limits)
enable_hard_limits = true         # If false, only Layer 2 circuit breakers apply (default: true)

